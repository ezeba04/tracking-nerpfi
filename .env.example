# ════════════════════════════════════════════════════════════
#  COOPERATIVA LOS TRAPITOS — Tracker de Programación Competitiva
# ════════════════════════════════════════════════════════════
#
#  Completá los datos de abajo para que la app pueda
#  consultar Codeforces y CSES por tu equipo.
#
#  ⚠️  NUNCA subas este archivo a un repositorio público.
# ════════════════════════════════════════════════════════════


# ─── CODEFORCES ──────────────────────────────────────────
#
#  Usuario y contraseña de UNA SOLA cuenta de Codeforces.
#  Se usa para entrar al sitio y bajar el código fuente
#  de las submissions de TODOS los miembros (la API no da el código).
#  Puede ser la cuenta de cualquiera del equipo.
#
#  ℹ️  La API pública trae los datos (verdicts, tiempos, etc)
#     de todos los miembros SIN login. El login solo es para el código.
#
CF_USERNAME=
CF_PASSWORD=


# ─── MIEMBROS DEL EQUIPO (3 personas) ───────────────────
#
#  Formato JSON. Un array con un objeto por cada miembro:
#
#    name:     Nombre (como quieras que aparezca en la app)
#    cf:       Handle de Codeforces (el username, ej: "tourist")
#    cses:     Username de CSES
#    csesPass: Contraseña de CSES de este miembro
#              ⚠️ CSES solo deja ver TUS submissions si estás logueado
#              con TU cuenta, así que necesitamos la pass de cada uno
#    csesId:   El número de usuario de CSES
#              (lo ves en la URL de tu perfil: https://cses.fi/user/XXXXX)
#
#  Ejemplo con 3 miembros:
#
#  TEAM_MEMBERS='[
#    {"name":"Juan",  "cf":"juan_cf",  "cses":"juan_cses",  "csesPass":"pass123", "csesId":"12345"},
#    {"name":"Pedro", "cf":"pedro_cf", "cses":"pedro_cses", "csesPass":"pass456", "csesId":"67890"},
#    {"name":"María", "cf":"maria_cf", "cses":"maria_cses", "csesPass":"pass789", "csesId":"11111"}
#  ]'
#
TEAM_MEMBERS='[]'


# ─── BASE DE DATOS ───────────────────────────────────────
#
#  Para desarrollo local, dejá la línea como está (SQLite).
#  Para producción/deploy, usá PostgreSQL:
#    DATABASE_URL="postgresql://usuario:contraseña@host:puerto/nombre_db"
#
DATABASE_URL="file:./dev.db"
